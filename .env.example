# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE_WEB_CLIENT_ID: Required for Google Sign-In.
# Users configure this with their Google Cloud Client ID.
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_PLACEHOLDER

# REMOTE_API_URL: Base URL of your backend hosted on Vercel (e.g. https://api.rfacto.com)
REMOTE_API_URL=https://api.rfacto.com

# STRIPE_PUBLISHABLE_KEY: Android client-side key for handling payments
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_PLACEHOLDER

# STRIPE_SECRET_KEY: Used in your backend on Vercel to create PaymentIntents. Included here for reference.
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_PLACEHOLDER
